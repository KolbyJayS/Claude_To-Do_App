{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "routes": [
    { "src": "/api/health", "dest": "/api/index.py" },
    { "src": "/api/auth/(.*)", "dest": "/api/index.py" },
    { "src": "/api/todos/(.*)", "dest": "/api/index.py" },
    { "src": "/api/todos", "dest": "/api/index.py" },
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
